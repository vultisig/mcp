# Ethereum JSON-RPC endpoint (default: https://ethereum-rpc.publicnode.com)
EVM_ETHEREUM_URL=

# Blockchair proxy base URL (default: https://api.vultisig.com/blockchair)
BLOCKCHAIR_API_URL=

# THORChain node base URL (default: https://thornode.ninerealms.com)
THORCHAIN_URL=

# Solana JSON-RPC endpoint (default: https://api.mainnet-beta.solana.com)
SOLANA_RPC_URL=

# XRP Ledger JSON-RPC endpoint (default: https://s1.ripple.com:51234)
XRP_RPC_URL=

# TRON JSON-RPC endpoint (default: https://api.trongrid.io)
TRON_RPC_URL=

# Cosmos Hub (Gaia) REST endpoint (default: https://cosmos-rest.publicnode.com)
GAIA_RPC_URL=
